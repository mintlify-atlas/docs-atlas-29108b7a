  "keyFeatures": [
    "RESTful API for anime themes, videos, and audio",
    "GraphQL API with advanced filtering and sorting",
    "Media streaming (audio and video) with multiple methods",
    "User playlists and external profile integration",
    "Filament admin panel for resource management",
    "Elasticsearch integration for advanced search",
    "Database dumps and backups",
    "Role-based permissions with Spatie Permission"
  ],
